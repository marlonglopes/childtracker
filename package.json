{
  "name": "childtracker",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "emulators": "firebase emulators:start",
    "dev": "concurrently \"npm run emulators\" \"npx expo start\"",
    "functions:serve": "cd functions && npm run serve",
    "functions:deploy": "cd functions && npm run deploy"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.5",
    "expo-notifications": "~0.29.14",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "firebase": "^10.12.4",
    "nativewind": "^4.0.36",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.53.0",
    "react-native": "0.76.9",
    "react-native-css-interop": "^0.2.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "react-native-worklets": "^0.8.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@react-native/js-polyfills": "^0.76.9",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.4",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "typescript": "~5.3.3"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "overrides": {
    "metro": "~0.81.5",
    "metro-config": "~0.81.5",
    "metro-core": "~0.81.5",
    "metro-runtime": "~0.81.5",
    "metro-source-map": "~0.81.5",
    "metro-transform-plugins": "~0.81.5",
    "metro-resolver": "~0.81.5",
    "metro-babel-transformer": "~0.81.5"
  },
  "private": true
}
